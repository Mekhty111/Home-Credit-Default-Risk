# ## 5. WOE + IV

# %%
# ── 5. WOE & IV ──────────────────────────────────────────────────────────────
def calc_woe_iv(df, feature, target, n_bins=10):
    tmp = df[[feature, target]].dropna().copy()
    N1  = tmp[target].sum()
    N0  = (1 - tmp[target]).sum()

    if not pd.api.types.is_numeric_dtype(tmp[feature]):
        tmp["bin"] = tmp[feature].astype(str)
    else:
        try:
            tmp["bin"] = pd.qcut(tmp[feature], q=n_bins, duplicates="drop")
        except Exception:
            tmp["bin"] = pd.cut(tmp[feature], bins=n_bins, duplicates="drop")

    g = tmp.groupby("bin")[target].agg(["sum","count"]).rename(
        columns={"sum":"events","count":"total"})
    g["non_events"] = g["total"] - g["events"]
    g["pct_e"] = (g["events"]     / N1).clip(lower=1e-6)
    g["pct_n"] = (g["non_events"] / N0).clip(lower=1e-6)
    g["WOE"]   = np.log(g["pct_e"] / g["pct_n"])
    g["IV"]    = (g["pct_e"] - g["pct_n"]) * g["WOE"]

    return g, round(g["IV"].sum(), 4)


# Compute IV on Train only
features_model = [c for c in train.columns
                  if c not in ["target"] and
                  pd.api.types.is_numeric_dtype(train[c])]

iv_results = {}
for feat in features_model:
    try:
        _, iv = calc_woe_iv(train, feat, "target")
        iv_results[feat] = iv
    except Exception as e:
        print(f"  IV error [{feat}]: {e}")

iv_df = (pd.DataFrame.from_dict(iv_results, orient="index", columns=["IV"])
           .sort_values("IV", ascending=False))

def iv_label(iv):
    if iv < 0.02:  return "🗑 Useless"
    if iv < 0.10:  return "❌ Weak"
    if iv < 0.30:  return "🟡 Medium"
    if iv < 0.50:  return "✅ Strong"
    return "🔍 Check leakage"

iv_df["strength"] = iv_df["IV"].apply(iv_label)
