    woe_tables[feat], _ = calc_woe_iv(train, feat, "target")

def apply_woe(df, feat, woe_table):
    x = df[feat]
    mapping = woe_table["WOE"].to_dict()
    if not pd.api.types.is_numeric_dtype(x):
        return x.astype(str).map(mapping)
    try:
        bins = pd.qcut(train[feat], q=10, duplicates="drop", retbins=True)[1]
        return pd.cut(x, bins=bins, include_lowest=True).map(mapping)
    except Exception:
        bins = pd.cut(train[feat], bins=10, duplicates="drop", retbins=True)[1]
        return pd.cut(x, bins=bins, include_lowest=True).map(mapping)

woe_cols = []
for feat in keep_features:
    col = f"{feat}_woe"
    woe_cols.append(col)
    for split in [train, val, df_oot]:
        split[col] = apply_woe(split, feat, woe_tables[feat])

print(f"\nWOE columns created: {len(woe_cols)}")

