# ## 2. Chi-Square Missing Predictiveness

# %%
# ── 2. Chi-Square Missing Predictiveness ─────────────────────────────────────
def missing_chi2_test(df, feature, target):
    tmp = df[[feature, target]].copy()
    tmp["is_missing"] = tmp[feature].isna().astype(int)

    n_missing = tmp["is_missing"].sum()
    if n_missing < 10:
        return None

    ct = pd.crosstab(tmp["is_missing"], tmp[target])
    chi2, p, dof, _ = chi2_contingency(ct)

    dr_missing = tmp[tmp["is_missing"] == 1][target].mean()
    dr_present = tmp[tmp["is_missing"] == 0][target].mean()

    return {
        "feature":     feature,
        "n_missing":   n_missing,
        "pct_missing": round(n_missing / len(tmp), 4),
        "dr_present":  round(dr_present, 4),
        "dr_missing":  round(dr_missing, 4) if not np.isnan(dr_missing) else None,
        "dr_lift":     round(dr_missing / (dr_present + 1e-9), 4),
        "chi2":        round(chi2, 4),
        "p_value":     round(p, 6),
        "predictive":  p < 0.05,
    }


features_all = [c for c in df.columns if c != "target"]
missing_report = pd.DataFrame(
    [r for f in features_all
     if (r := missing_chi2_test(df, f, "target")) is not None]
).sort_values("p_value")

missing_report["recommendation"] = missing_report.apply(
    lambda r: "🔴 MNAR — create flag" if r["predictive"] and r["dr_lift"] > 1.5
    else "🟡 MNAR — create flag"      if r["predictive"]
    else "➡️ MCAR — impute", axis=1)

