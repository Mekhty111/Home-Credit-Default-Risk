# ## 9. KS + AUC + Gini

# %%
# ── 9. KS + AUC + Gini ───────────────────────────────────────────────────────
def full_eval(name, y_true, y_score):
    auc  = roc_auc_score(y_true, y_score)
    gini = 2 * auc - 1
    ks, _= ks_2samp(y_score[y_true==1], y_score[y_true==0])
    bs   = brier_score_loss(y_true, y_score)
    print(f"  {name:8s} | AUC={auc:.4f} | Gini={gini:.4f} | "
          f"KS={ks:.4f} | Brier={bs:.4f}")
    return dict(split=name, auc=auc, gini=gini, ks=ks, brier=bs)

print("\n── Metrics ──────────────────────────────────────────────────")
metrics = [
    full_eval("Train", y_tr,  p_tr),
    full_eval("Val",   y_val, p_val),
    full_eval("OOT",   y_oot, p_oot),
]
metrics_df = pd.DataFrame(metrics)

# %%
# KS Plot
def plot_ks(y_true, y_score, title="KS Plot"):
    bad  = np.sort(y_score[y_true == 1])
    good = np.sort(y_score[y_true == 0])
    x    = np.linspace(0, 1, 1000)
    cdf_bad  = np.searchsorted(bad,  x, "right") / len(bad)
    cdf_good = np.searchsorted(good, x, "right") / len(good)
    diff = np.abs(cdf_bad - cdf_good)
    ks_x = x[np.argmax(diff)]

    plt.figure(figsize=(8, 4))
    plt.plot(x, cdf_bad,  color="red",       label="Defaults")
    plt.plot(x, cdf_good, color="steelblue", label="Non-defaults")
    plt.annotate("", xy=(ks_x, cdf_good[np.argmax(diff)]),
                 xytext=(ks_x, cdf_bad[np.argmax(diff)]),
                 arrowprops=dict(arrowstyle="<->", color="black", lw=2))
    plt.text(ks_x + 0.01,
             (cdf_bad[np.argmax(diff)] + cdf_good[np.argmax(diff)]) / 2,
             f"KS={diff.max():.3f}", fontweight="bold")
    plt.xlabel("Score"); plt.ylabel("Cumulative %")
    plt.title(title); plt.legend()
    plt.tight_layout(); plt.show()

plot_ks(y_oot.values, p_oot, "KS Plot — OOT")

