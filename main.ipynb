for ax, col, thresh, color in [
    (axes[0], "auc", None,  "steelblue"),
    (axes[1], "ks",  None,  "green"),
    (axes[2], "psi", [0.1, 0.2], "coral"),
]:
    ax.plot(monthly_df["bucket"], monthly_df[col], marker="o", color=color)
    if thresh:
        for t, lc in zip(thresh, ["orange","red"]):
            ax.axhline(t, linestyle="--", color=lc, alpha=0.7, label=f"{col}={t}")
    ax.set_title(f"{col.upper()} by OOT bucket")
    ax.set_xlabel("Bucket"); ax.legend(fontsize=8)

plt.suptitle("OOT Degradation Monitoring", fontsize=13)
plt.tight_layout(); plt.show()

