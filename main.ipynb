# ## 6. Univariate AUC

# %%
# ── 6. Univariate AUC ────────────────────────────────────────────────────────
def univariate_auc(df, features, target):
    rows = []
    for feat in features:
        tmp = df[[feat, target]].dropna()
        if len(tmp) < 50 or tmp[target].sum() < 10:
            continue
        x = tmp[feat]
        if not pd.api.types.is_numeric_dtype(x):
            x = x.astype("category").cat.codes
        try:
            auc = roc_auc_score(tmp[target], x)
            auc = max(auc, 1 - auc)
            rows.append({"feature": feat, "univariate_auc": round(auc, 4)})
        except Exception:
            pass
    return pd.DataFrame(rows).sort_values("univariate_auc", ascending=False)

uni_raw = univariate_auc(train, keep_features, "target")
uni_woe = univariate_auc(train, woe_cols,      "target")
uni_woe["feature_raw"] = uni_woe["feature"].str.replace("_woe", "")

comparison = uni_raw.merge(
    uni_woe.rename(columns={"univariate_auc":"auc_woe",
                             "feature":"feature_woe"}),
    left_on="feature", right_on="feature_raw", how="inner")
comparison["delta"] = (comparison["auc_woe"] - comparison["univariate_auc"]).round(4)
print(comparison[["feature","univariate_auc","auc_woe","delta"]].to_string(index=False))

