# ## 10. PSI

# %%
# ── 10. PSI ──────────────────────────────────────────────────────────────────
def calc_psi(expected, actual, bins=10, min_pct=1e-4):
    bpts = np.unique(np.nanpercentile(expected, np.linspace(0, 100, bins+1)))
    e_cnt = np.histogram(expected, bins=bpts)[0]
    a_cnt = np.histogram(actual,   bins=bpts)[0]
    e_pct = np.clip(e_cnt / len(expected), min_pct, None)
    a_pct = np.clip(a_cnt / len(actual),   min_pct, None)
    psi   = ((a_pct - e_pct) * np.log(a_pct / e_pct)).sum()
    return round(psi, 4)

def psi_label(psi):
    if psi < 0.10: return "✅ Stable"
    if psi < 0.20: return "⚠️ Monitor"
    return "❌ Retrain"

# PSI for each feature
print("── PSI: Train vs OOT ────────────────────────────────────────")
psi_rows = []
for col in final_cols:
    psi = calc_psi(X_tr[col].values, X_oot[col].values)
    psi_rows.append({"feature": col, "PSI": psi, "status": psi_label(psi)})
psi_df = pd.DataFrame(psi_rows).sort_values("PSI", ascending=False)
print(psi_df.to_string(index=False))

# PSI of score
score_psi = calc_psi(p_tr, p_oot)
print(f"\nScore PSI: {score_psi} — {psi_label(score_psi)}")

