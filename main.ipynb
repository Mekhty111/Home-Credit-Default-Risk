# ## 7. VIF — Multicollinearity Check

# %%
# ── 7. VIF ───────────────────────────────────────────────────────────────────
def calc_vif(df, cols):
    X = df[cols].dropna()
    return pd.DataFrame({
        "feature": cols,
        "VIF": [variance_inflation_factor(X.values, i) for i in range(len(cols))]
    }).sort_values("VIF", ascending=False).round(2)

def iterative_vif_removal(df, cols, iv_dict, threshold=VIF_THRESH):
    cols = cols.copy()
    iteration = 0
    while True:
        vif_df = calc_vif(df, cols)
        max_vif = vif_df["VIF"].max()
        if max_vif <= threshold:
            print(f"✅ Done in {iteration} iterations. Features left: {len(cols)}")
            break
        candidates = vif_df[vif_df["VIF"] > threshold]["feature"].tolist()
        worst = min(candidates,
                    key=lambda f: iv_dict.get(f.replace("_woe",""), 0))
        print(f"  Iter {iteration+1}: removing {worst} "
              f"(VIF={vif_df.set_index('feature').loc[worst,'VIF']:.1f})")
        cols.remove(worst)
        iteration += 1
    return cols, calc_vif(df, cols)

iv_dict = iv_df["IV"].to_dict()
final_cols, final_vif = iterative_vif_removal(train, woe_cols, iv_dict)
print(f"\nFinal VIF table:\n{final_vif.to_string(index=False)}")

