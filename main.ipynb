# ## 11. Calibration → Real Default Rate

# %%
# ── 11. Calibration ──────────────────────────────────────────────────────────
# class_weight="balanced" inflates probabilities → need calibration

# Platt Scaling (fit on Val, apply on OOT)
platt = LogisticRegression(C=1e10, max_iter=1000)
platt.fit(p_val.reshape(-1, 1), y_val)
p_oot_platt = platt.predict_proba(p_oot.reshape(-1, 1))[:, 1]

# Prior Probability Adjustment
train_dr = y_tr.mean()

def prior_adjust(p, train_dr, real_dr):
    p = np.clip(p, 1e-6, 1 - 1e-6)
    ratio = (real_dr / (1 - real_dr)) / (train_dr / (1 - train_dr))
    odds  = (p / (1 - p)) * ratio
    return odds / (1 + odds)

p_oot_adj = prior_adjust(p_oot, train_dr, REAL_DR)

# Reliability Diagram
fig, axes = plt.subplots(1, 2, figsize=(14, 5))

for p_scores, label, color in [
    (p_oot,       "Uncalibrated",       "red"),
    (p_oot_platt, "Platt Scaling",      "steelblue"),
    (p_oot_adj,   "Prior Adjustment",   "green"),
]:
    fop, mpv = calibration_curve(y_oot, p_scores, n_bins=10, strategy="quantile")
    axes[0].plot(mpv, fop, "o-", label=label, color=color)

axes[0].plot([0,1],[0,1],"k--", label="Perfect")
axes[0].axhline(REAL_DR, linestyle=":", color="gray", label=f"Real DR={REAL_DR:.1%}")
axes[0].set_xlabel("Mean predicted probability")
axes[0].set_ylabel("Fraction of positives")
axes[0].set_title("Reliability Diagram — OOT")
axes[0].legend(fontsize=8)

# Distribution of predicted probabilities
axes[1].hist(p_oot,       bins=50, alpha=0.4, color="red",       label="Uncalibrated")
axes[1].hist(p_oot_adj,   bins=50, alpha=0.4, color="green",     label="Prior Adjusted")
axes[1].hist(p_oot_platt, bins=50, alpha=0.4, color="steelblue", label="Platt")
axes[1].axvline(REAL_DR, linestyle="--", color="black", label=f"Real DR={REAL_DR:.1%}")
axes[1].set_xlabel("Predicted probability")
axes[1].set_title("Distribution of Predicted Probabilities")
axes[1].legend(fontsize=8)

plt.suptitle("Calibration Analysis", fontsize=13)
plt.tight_layout(); plt.show()

print(f"\nMean probability before calibration: {p_oot.mean():.4f}")
print(f"Mean probability after calibration:  {p_oot_adj.mean():.4f}")
print(f"Real default rate:                   {REAL_DR:.4f}")

# %%
# Scorecard — convert calibrated PD to score points
def pd_to_score(p, offset=OFFSET, factor=FACTOR, center_pd=REAL_DR):
    p    = np.clip(p, 1e-6, 1 - 1e-6)
    odds = p / (1 - p)
    return offset - factor * np.log(odds / (center_pd / (1 - center_pd)))

df_oot["score"] = pd_to_score(p_oot_adj)
print(f"\nScore distribution (OOT):\n{df_oot['score'].describe().round(1)}")

