# ── 3. Feature Engineering ───────────────────────────────────────────────────
def feature_engineering(df):
    df = df.copy()

    # Impute missing with median (after creating flags)
    for col in ["MonthlyIncome", "NumberOfDependents"]:
        df[col] = df[col].fillna(df[col].median())

    # Clip extreme outliers
    df["age"] = df["age"].clip(18, 100)
    df["MonthlyIncome"] = df["MonthlyIncome"].clip(0, 50_000)
    df["RevolvingUtilizationOfUnsecuredLines"] = \
        df["RevolvingUtilizationOfUnsecuredLines"].clip(0, 1)

    # Total delinquencies
    df["total_delinq"] = (
        df["NumberOfTime30-59DaysPastDueNotWorse"] +
        df["NumberOfTime60-89DaysPastDueNotWorse"] +
        df["NumberOfTimes90DaysLate"]
    )
    df["has_any_delinq"] = (df["total_delinq"] > 0).astype(int)

    # Debt burden
    df["monthly_debt"] = (df["RevolvingUtilizationOfUnsecuredLines"]
                          * df["MonthlyIncome"])
    df["debt_to_income"] = df["monthly_debt"] / (df["MonthlyIncome"] + 1)

    # Credit lines per age
    df["lines_per_age"] = (
        df["NumberOfOpenCreditLinesAndLoans"] / (df["age"] + 1)
    )

    # Log transforms (skewed features)
    for col in ["MonthlyIncome", "monthly_debt", "debt_to_income"]:
        df[f"log_{col}"] = np.log1p(df[col].clip(lower=0))

    return df

df = feature_engineering(df)
